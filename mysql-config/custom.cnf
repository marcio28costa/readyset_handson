[mysqld]
server-id                = 1
log_bin                  = mysql-bin
binlog_format            = ROW
binlog_row_image         = FULL
expire_logs_days         = 7
gtid_mode                = ON
enforce_gtid_consistency = ON
innodb_buffer_pool_size  = 256M
max_connections          = 200
character_set_server     = utf8mb4
collation_server         = utf8mb4_unicode_ci

